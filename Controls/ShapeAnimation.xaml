<UserControl x:Class="IceSky.WpfLoading.Sample.Controls.ShapeAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IceSky.WpfLoading.Sample.Controls" 
             xmlns:anim="clr-namespace:IceSky.WpfLoading.Animations;assembly=IceSky.WpfLoading"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" ItemWidth="150" ItemHeight="100">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="SimpleArc" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:SimpleArc Stroke="#4F46E5" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="DoubleArc" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:DoubleArc Stroke="#EC4899" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="GradientArc" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:GradientArc StrokeThickness="15" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="ThreeArc" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:ThreeArc StrokeThickness="6" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="FourArc" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:FourArc Stroke="#EC4899" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Circle" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Circle Stroke="#10B981" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="RectDraw" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:RectDraw Stroke="#4F46E5" StrokeThickness="10" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="RectDraw2" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:RectDraw2 Stroke="#EC4899" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="DrawStar" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:DrawStar Stroke="#10B981" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="NenoStar" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:NenoStar Stroke="#4F46E5" StrokeThickness="10" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="PulseTriangle" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:PulseTriangle Stroke="#EC4899" StrokeThickness="3" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BlockJump" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BlockJump Stroke="#10B981" StrokeThickness="8" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Flame" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Flame Stroke="#4F46E5" StrokeThickness="10" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="DiamondStar" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:DiamondStar Stroke="#EC4899" StrokeThickness="3" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BlockScale" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BlockScale Fill="#10B981" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BlockHourglass" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BlockHourglass Fill="#CC4F46E5" Stroke="#4F46E5" StrokeThickness="5" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Charge" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Charge Stroke="#EC4899" Fill="DodgerBlue" StrokeThickness="5" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Cross" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Cross Fill="#10B981" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Quantum" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Quantum Fill="#4F46E5" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="TonePillar" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:TonePillar Stroke="#EC4899" StrokeThickness="10" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Radar" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Radar Fill="#10B981" Stroke="#CC10B981" StrokeThickness="2" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BoxShift" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BoxShift Fill="#4F46E5" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BlockWave" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BlockWave Fill="#EC4899" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BlockSway" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BlockSway Fill="#10B981" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="RotateSkew" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:RotateSkew Fill="#664F46E5" Stroke="#4F46E5" StrokeThickness="4" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Satellites" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Satellites Fill="#EC4899" Stroke="#33EC4899" StrokeThickness="2" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="HollowStar" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:HollowStar Fill="#10B981" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="RotatingBall" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:RotatingBall Fill="#4F46E5" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="MovingTriangle" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:MovingTriangle Fill="#EC4899" Stroke="#EC4899" Width="50" Height="50"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BlockFlow" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:BlockFlow Fill="#10B981" Width="50" Height="50"/>
                </StackPanel>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
