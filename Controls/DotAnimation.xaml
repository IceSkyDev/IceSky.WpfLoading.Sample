                    <anim:Bouncing Color="#4F46E5"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Elastic" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                    <anim:Elastic Color="#EC4899"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
